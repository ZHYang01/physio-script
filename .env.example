# Local Transcription (faster-whisper) — runs 100% offline, no audio leaves your Mac.
# Model options (accuracy vs speed): large-v3-turbo, medium.en, small.en, base.en
WHISPER_MODEL=large-v3-turbo
# Use small.en or base.en if you want faster live transcription on slower machines.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Cliniko Configuration (optional — only for "Push to Cliniko")
CLINIKO_API_KEY=your-cliniko-api-key-here
CLINIKO_SHARD=au1
CLINIKO_EMAIL=your-email@example.com

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Recording Settings
CHUNK_DURATION_SECONDS=5
SAMPLE_RATE=16000
CHANNELS=1
